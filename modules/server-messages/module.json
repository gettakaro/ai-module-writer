          {
            "text": "Welcome to the server!"
          }
        ],
        "maxItems": 100,
        "items": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1,
              "pattern": ".*\\S.*",
              "description": "Exact message text to broadcast. Supports {playerCount} and {serverName} placeholders. Unknown placeholders are left unchanged. Must contain at least one non-whitespace character."
            },
            "weight": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20,
              "default": 1,
              "description": "Relative weight used only when order is set to random. If order is sequential, this field is ignored and can usually stay at 1. Enter a whole number from 1 to 20; larger values are rejected during validation."
            }
          },
          "required": [
            "text"
          ],
          "additionalProperties": false
        }
      },

{
  "name": "server-messages",
  "description": "Broadcast scheduled server announcements with sequential or weighted shuffle-bag rotation.",
  "version": "latest",
  "supportedGames": [
    "all"
  ],
  "config": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "messages": {
        "type": "array",
        "description": "Messages to broadcast. Empty arrays are allowed; when no messages are configured the cronjob exits quietly without sending or advancing rotation state.",
